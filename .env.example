# Copiar a .env: cp .env.example .env
# Docker Compose lee estas variables del .env para el servicio db.
# Mantén DATABASE_URL acorde a POSTGRES_* y al puerto mapeado (5432 por defecto).

POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=blacklist_db

DATABASE_URL=postgresql://postgres:password@localhost:5432/blacklist_db
STATIC_TOKEN=my-static-bearer-token
JWT_SECRET_KEY=super-secret-static-key
